{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@archon/ui-types": [
        "../../src/shared/archon-preload-public-types.ts"
      ],
      "@archon/platform": [
        "../../packages/archon-platform/src/index.ts"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "archon-globals.d.ts",
    "../../src/renderer/store/thunk-extra.d.ts",
    "../../src/types/window.d.ts",
    "../../src/types/observable-runtime.d.ts",
    "../../src/types/observable-inspector.d.ts",
    "../../src/types/observable-stdlib.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
