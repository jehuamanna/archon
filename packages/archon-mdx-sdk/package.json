{
  "name": "@nodex-studio/mdx-sdk",
  "version": "0.1.1",
  "type": "module",
  "description": "Schema and validation rules for Archon MDX mini-app notes. Components/hooks live in @archon/mdx-sdk-runtime.",
  "keywords": [
    "archon",
    "mdx",
    "schema",
    "json-schema"
  ],
  "license": "UNLICENSED",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./prop-specs": {
      "types": "./dist/prop-specs.d.ts",
      "import": "./dist/prop-specs.js"
    },
    "./validation": {
      "types": "./dist/validation.d.ts",
      "import": "./dist/validation.js"
    },
    "./json-schema": {
      "types": "./dist/json-schema.d.ts",
      "import": "./dist/json-schema.js"
    },
    "./system-prompt": {
      "types": "./dist/system-prompt.d.ts",
      "import": "./dist/system-prompt.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "src"
  ],
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
